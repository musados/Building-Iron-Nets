# העתק קובץ זה ל-.env ומלא את הערכים:
#   cp .env.example .env
#
# docker compose קורא את הקובץ אוטומטית, וגם השרת בהרצה מקומית (python-dotenv).

# מפתח Claude API — נדרש רק לחילוץ כמויות מתוכניות (AI).
# יצירת מפתח: https://console.anthropic.com
ANTHROPIC_API_KEY=

# המודל לחילוץ כמויות (אופציונלי). ברירת מחדל: claude-opus-4-8.
#   claude-opus-4-8  — ברירת המחדל, מהיר וזול יותר ($5/$25 למיליון טוקנים)
#   claude-fable-5   — המודל החזק ביותר ($10/$50 למיליון טוקנים).
#                      דורש ארגון עם שמירת נתונים של 30 יום (לא זמין ב-ZDR).
#                      אם מסווגי הבטיחות שלו מסרבים לבקשה, השרת עובר
#                      אוטומטית ל-Opus 4.8 באותה קריאה (server-side fallback).
# דוגמה:
# CLAUDE_MODEL=claude-fable-5
CLAUDE_MODEL=

# ---------------------------------------------------------------------------
# חשבונות ושמירת הזמנות בשרת (אופציונלי — בלי זה האפליקציה עובדת מקומית בלבד)
# ---------------------------------------------------------------------------

# סיסמאות Postgres — שלושה משתמשים נפרדים: superuser, סכמת auth, סכמת content.
# ההפרדה מבטיחה שפריצה לשירות אחד לא חושפת את נתוני השני.
# חובה להחליף בפרודקשן! נקבעות באתחול הראשון של ה-volume של postgres
# (שינוי אחרי האתחול דורש ALTER ROLE או מחיקת ה-volume).
POSTGRES_SUPERUSER_PASSWORD=
AUTH_DB_PASSWORD=
CONTENT_DB_PASSWORD=

# התחברות Google — כל ה-client IDs המורשים, מופרדים בפסיק
# (web / iOS / Android — יצירה ב-https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_IDS=
# ה-client של אפליקציית הווב + הסוד שלו — נדרשים להחלפת ה-code בזרימת ווב.
# הסוד נשאר רק בשרת ה-auth ולעולם לא מגיע לקליינט.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=

# התחברות Apple — ה-bundle IDs המורשים (audience של ה-identity token)
APPLE_BUNDLE_IDS=
