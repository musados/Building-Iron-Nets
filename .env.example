# העתק קובץ זה ל-.env ומלא את הערכים:
#   cp .env.example .env
#
# docker compose קורא את הקובץ אוטומטית, וגם השרת בהרצה מקומית (python-dotenv).

# מפתח Claude API — נדרש רק לחילוץ כמויות מתוכניות (AI).
# יצירת מפתח: https://console.anthropic.com
ANTHROPIC_API_KEY=

# המודל לחילוץ כמויות (אופציונלי). ברירת מחדל: claude-opus-4-8.
#   claude-opus-4-8  — ברירת המחדל, מהיר וזול יותר ($5/$25 למיליון טוקנים)
#   claude-fable-5   — המודל החזק ביותר ($10/$50 למיליון טוקנים).
#                      דורש ארגון עם שמירת נתונים של 30 יום (לא זמין ב-ZDR).
#                      אם מסווגי הבטיחות שלו מסרבים לבקשה, השרת עובר
#                      אוטומטית ל-Opus 4.8 באותה קריאה (server-side fallback).
# דוגמה:
# CLAUDE_MODEL=claude-fable-5
CLAUDE_MODEL=
